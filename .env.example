# =============================================================================
# Health Portal - Umgebungsvariablen
# Diese Datei nach .env kopieren und Werte anpassen.
# NIEMALS die .env-Datei ins Repository einchecken!
# =============================================================================

# Datenbank
DB_NAME=portal
DB_USERNAME=portal
DB_PASSWORD=SICHERES_PASSWORT_HIER_SETZEN

# JWT (mindestens 32 Zeichen, zufaellig generiert)
# Generieren: openssl rand -base64 48
JWT_SECRET=ZUFAELLIGES_SECRET_HIER_SETZEN_MINDESTENS_32_ZEICHEN

# CORS erlaubte Origins (kommagetrennt)
CORS_ALLOWED_ORIGINS=http://localhost:4200

# Logging (DEBUG nur fuer Entwicklung, INFO fuer Produktion)
LOG_LEVEL=INFO
